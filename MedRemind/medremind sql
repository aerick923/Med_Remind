CREATE TABLE users (
    id INT AUTO_INCREMENT PRIMARY KEY,
    username VARCHAR(50) UNIQUE,
    password VARCHAR(100),
    full_name VARCHAR(100),
    age INT,
    gender VARCHAR(10)
);

CREATE TABLE medications (
    id INT AUTO_INCREMENT PRIMARY KEY,
    user_id INT,
    medicine_name VARCHAR(100),
    dosage VARCHAR(50),
    med_time VARCHAR(50),
    instructions TEXT
);

CREATE TABLE appointments (
    id INT AUTO_INCREMENT PRIMARY KEY,
    user_id INT,
    doctor_name VARCHAR(100),
    clinic VARCHAR(100),
    app_date VARCHAR(50),
    app_time VARCHAR(50),
    purpose TEXT
);
