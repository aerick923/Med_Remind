# =========================================================
# LOGIN SCREEN -> login()
# =========================================================
def login():
    clear()
    make_title("MedRemind Login")

    card = tk.Frame(root, bg=CARD_COLOR, padx=30, pady=30)
    card.pack(pady=30)

    tk.Label(card, text="Username", font=("Arial", 12), bg=CARD_COLOR).grid(row=0, column=0, sticky="w", pady=8)
    username_entry = tk.Entry(card, font=("Arial", 12), width=28)
    username_entry.grid(row=0, column=1, pady=8)

    tk.Label(card, text="Password", font=("Arial", 12), bg=CARD_COLOR).grid(row=1, column=0, sticky="w", pady=8)
    password_entry = tk.Entry(card, font=("Arial", 12), width=28, show="*")
    password_entry.grid(row=1, column=1, pady=8)

    feedback_label = tk.Label(card, text="", font=("Arial", 10), bg=CARD_COLOR, fg="red")
    feedback_label.grid(row=2, column=0, columnspan=2, pady=5)

    def do_login():
        global current_user
        username = username_entry.get().strip()
        password = password_entry.get().strip()

        if not username or not password:
            feedback_label.config(text="Please enter username and password.")
            return

        user = authenticate_user(username, password)
        if user:
            current_user = user
            home()
        else:
            feedback_label.config(text="Invalid username or password.")

    btn_frame = tk.Frame(card, bg=CARD_COLOR)
    btn_frame.grid(row=3, column=0, columnspan=2, pady=15)

    make_button(btn_frame, "Login", do_login).grid(row=0, column=0, padx=8)
    make_button(btn_frame, "Sign Up", signup).grid(row=0, column=1, padx=8)

# =========================================================
# SIGNUP SCREEN -> signup()
# =========================================================
def signup():
    clear()
    make_title("Create Account")

    card = tk.Frame(root, bg=CARD_COLOR, padx=30, pady=30)
    card.pack(pady=20)

    labels = ["Full Name", "Age", "Gender", "Username", "Password"]
    entries = {}

    for i, label_text in enumerate(labels):
        tk.Label(card, text=label_text, font=("Arial", 12), bg=CARD_COLOR).grid(row=i, column=0, sticky="w", pady=8)

        if label_text == "Gender":
            gender_cb = ttk.Combobox(card, values=["Male", "Female", "Other"], state="readonly", width=26)
            gender_cb.grid(row=i, column=1, pady=8)
            entries["Gender"] = gender_cb
        else:
            show_val = "*" if label_text == "Password" else ""
            entry = tk.Entry(card, font=("Arial", 12), width=28, show=show_val)
            entry.grid(row=i, column=1, pady=8)
            entries[label_text] = entry

    feedback = tk.Label(card, text="", font=("Arial", 10), bg=CARD_COLOR, fg="red")
    feedback.grid(row=5, column=0, columnspan=2, pady=5)

    def register():
        full_name = entries["Full Name"].get().strip()
        age = entries["Age"].get().strip()
        gender = entries["Gender"].get().strip()
        username = entries["Username"].get().strip()
        password = entries["Password"].get().strip()

        if not all([full_name, age, gender, username, password]):
            feedback.config(text="Please complete all fields.")
            return

        if not age.isdigit():
            feedback.config(text="Age must be a number.")
            return

        ok, msg = create_user(username, password, full_name, int(age), gender)
        if ok:
            messagebox.showinfo("Success", msg)
            login()
        else:
            feedback.config(text=msg)

    btn_frame = tk.Frame(card, bg=CARD_COLOR)
    btn_frame.grid(row=6, column=0, columnspan=2, pady=15)
    make_button(btn_frame, "Create Account", register).grid(row=0, column=0, padx=8)
    make_button(btn_frame, "Back", login).grid(row=0, column=1, padx=8)

