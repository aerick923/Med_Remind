        if not doctor_entry.get().strip():
            return False, "Doctor name is required."
        if not clinic_entry.get().strip():
            return False, "Clinic is required."
        if not date_entry.get().strip():
            return False, "Date is required."
        if not time_entry.get().strip():
            return False, "Time is required."
        try:
            datetime.strptime(date_entry.get().strip(), "%Y-%m-%d")
        except ValueError:
            return False, "Date must be YYYY-MM-DD."
        return True, ""

    def add_record():
        ok, msg = validate_form()
        if not ok:
            feedback.config(text=msg)
            return

        success, result = add_appointment_db(
            current_user["id"],
            doctor_entry.get().strip(),
            clinic_entry.get().strip(),
            date_entry.get().strip(),
            time_entry.get().strip(),
            purpose_entry.get().strip()
        )
        if success:
            load_data()
            clear_form()
            messagebox.showinfo("Success", result)
        else:
            feedback.config(text=result)

    def update_record():
        if not selected_app_id.get():
            feedback.config(text="Select an appointment to update.")
            return

        ok, msg = validate_form()
        if not ok:
            feedback.config(text=msg)
            return

        success, result = update_appointment_db(
            int(selected_app_id.get()),
            doctor_entry.get().strip(),
            clinic_entry.get().strip(),
            date_entry.get().strip(),
            time_entry.get().strip(),
            purpose_entry.get().strip()
        )
        if success:
            load_data()
            clear_form()
            messagebox.showinfo("Success", result)
        else:
            feedback.config(text=result)

    def delete_record():
        if not selected_app_id.get():
            feedback.config(text="Select an appointment to delete.")
            return

        confirm = messagebox.askyesno("Confirm Delete", "Delete selected appointment?")
        if not confirm:
            return

        success, result = delete_appointment_db(int(selected_app_id.get()))
        if success:
            load_data()
            clear_form()
            messagebox.showinfo("Success", result)
        else:
            feedback.config(text=result)

    def on_select(event):
        selected = tree.focus()
        if not selected:
            return
        values = tree.item(selected, "values")
        if not values:
            return

        clear_form()
        selected_app_id.set(values[0])
        doctor_entry.insert(0, values[1])
        clinic_entry.insert(0, values[2])
        date_entry.insert(0, values[3])
        time_entry.insert(0, values[4])
        purpose_entry.insert(0, values[5])

    tree.bind("<<TreeviewSelect>>", on_select)

    btns = tk.Frame(form, bg=CARD_COLOR)
    btns.grid(row=6, column=0, columnspan=2, pady=10)

    make_button(btns, "Add", add_record, 10).grid(row=0, column=0, padx=4, pady=4)
    make_button(btns, "Update", update_record, 10).grid(row=0, column=1, padx=4, pady=4)
    make_button(btns, "Delete", delete_record, 10).grid(row=0, column=2, padx=4, pady=4)
    make_button(btns, "Clear", clear_form, 10).grid(row=1, column=0, padx=4, pady=4)
    make_button(btns, "Back", home, 10).grid(row=1, column=1, padx=4, pady=4)

    load_data()

