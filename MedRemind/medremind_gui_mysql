# PROFILE -> profile()
# =========================================================
def profile():
    clear()
    make_title("Profile")

    user = get_user_by_id(current_user["id"])
    if not user:
        messagebox.showerror("Error", "User not found.")
        home()
        return

    card = tk.Frame(root, bg=CARD_COLOR, padx=35, pady=35)
    card.pack(pady=25)

    info = [
        ("Full Name", user["full_name"]),
        ("Username", user["username"]),
        ("Age", user["age"]),
        ("Gender", user["gender"]),
    ]

    for i, (label_text, value) in enumerate(info):
        tk.Label(card, text=f"{label_text}:", font=("Arial", 12, "bold"), bg=CARD_COLOR).grid(row=i, column=0, sticky="w", pady=8, padx=10)
        tk.Label(card, text=f"{value}", font=("Arial", 12), bg=CARD_COLOR).grid(row=i, column=1, sticky="w", pady=8, padx=10)

    make_button(card, "Back", home, 12).grid(row=len(info), column=0, columnspan=2, pady=20)

