}

# =========================================================
# DB LAYER
# =========================================================
def get_connection():
    return mysql.connector.connect(**DB_CONFIG)

def initialize_database():
    conn = None
    cursor = None
    try:
        # connect without database first if needed
        temp_config = DB_CONFIG.copy()
        db_name = temp_config.pop("database")
        conn = mysql.connector.connect(**temp_config)
        cursor = conn.cursor()

        cursor.execute(f"CREATE DATABASE IF NOT EXISTS {db_name}")
        cursor.execute(f"USE {db_name}")

        cursor.execute("""
            CREATE TABLE IF NOT EXISTS users (
                id INT AUTO_INCREMENT PRIMARY KEY,
                username VARCHAR(50) NOT NULL UNIQUE,
                password VARCHAR(255) NOT NULL,
                full_name VARCHAR(100) NOT NULL,
                age INT DEFAULT NULL,
                gender VARCHAR(20) DEFAULT NULL
            )
        """)

        cursor.execute("""
            CREATE TABLE IF NOT EXISTS medications (
                id INT AUTO_INCREMENT PRIMARY KEY,
                user_id INT NOT NULL,
                medicine_name VARCHAR(100) NOT NULL,
                dosage VARCHAR(100) NOT NULL,
                med_time VARCHAR(50) NOT NULL,
                instructions VARCHAR(255) DEFAULT '',
                FOREIGN KEY (user_id) REFERENCES users(id) ON DELETE CASCADE
            )
        """)

        cursor.execute("""
            CREATE TABLE IF NOT EXISTS appointments (
                id INT AUTO_INCREMENT PRIMARY KEY,
                user_id INT NOT NULL,
                doctor_name VARCHAR(100) NOT NULL,
                clinic VARCHAR(100) NOT NULL,
                app_date VARCHAR(30) NOT NULL,
                app_time VARCHAR(30) NOT NULL,
                purpose VARCHAR(255) DEFAULT '',
                FOREIGN KEY (user_id) REFERENCES users(id) ON DELETE CASCADE
            )
        """)

        conn.commit()
    except Error as e:
        messagebox.showerror("Database Error", f"Failed to initialize database.\n{e}")
    finally:
        if cursor:
            cursor.close()
        if conn:
            conn.close()

def create_user(username, password, full_name, age, gender):
    conn = None
    cursor = None
    try:
        conn = get_connection()
        cursor = conn.cursor()
        sql = """
            INSERT INTO users (username, password, full_name, age, gender)
            VALUES (%s, %s, %s, %s, %s)
        """
        cursor.execute(sql, (username, password, full_name, age, gender))
        conn.commit()
        return True, "Account created successfully."
    except mysql.connector.IntegrityError:
        return False, "Username already exists."
    except Error as e:
        return False, str(e)
    finally:
        if cursor:
            cursor.close()
        if conn:
            conn.close()

def authenticate_user(username, password):
    conn = None
    cursor = None
    try:
        conn = get_connection()
        cursor = conn.cursor(dictionary=True)
        sql = "SELECT * FROM users WHERE username = %s AND password = %s"
        cursor.execute(sql, (username, password))
        user = cursor.fetchone()
        return user
    except Error as e:
        messagebox.showerror("Database Error", str(e))
        return None
    finally:
        if cursor:
            cursor.close()
        if conn:
            conn.close()

def get_user_by_id(user_id):
