def manage_medications():
    clear()
    make_title("Medication Tracker")

    selected_med_id = tk.StringVar(value="")

    top = tk.Frame(root, bg=BG_COLOR)
    top.pack(fill="x", padx=20)

    form = tk.LabelFrame(top, text="Medication Form", bg=CARD_COLOR, padx=15, pady=15, font=("Arial", 11, "bold"))
    form.pack(side="left", fill="y", padx=10, pady=10)

    tk.Label(form, text="Medicine Name", bg=CARD_COLOR).grid(row=0, column=0, sticky="w", pady=6)
    medicine_name_entry = tk.Entry(form, width=28)
    medicine_name_entry.grid(row=0, column=1, pady=6)

    tk.Label(form, text="Dosage", bg=CARD_COLOR).grid(row=1, column=0, sticky="w", pady=6)
    dosage_entry = tk.Entry(form, width=28)
    dosage_entry.grid(row=1, column=1, pady=6)

    tk.Label(form, text="Time", bg=CARD_COLOR).grid(row=2, column=0, sticky="w", pady=6)
    time_entry = tk.Entry(form, width=28)
    time_entry.grid(row=2, column=1, pady=6)

    tk.Label(form, text="Instructions", bg=CARD_COLOR).grid(row=3, column=0, sticky="w", pady=6)
    instructions_entry = tk.Entry(form, width=28)
    instructions_entry.grid(row=3, column=1, pady=6)

    feedback = tk.Label(form, text="", bg=CARD_COLOR, fg="red")
    feedback.grid(row=4, column=0, columnspan=2, pady=6)

    table_frame = tk.LabelFrame(top, text="Medication Records", bg=BG_COLOR, padx=10, pady=10, font=("Arial", 11, "bold"))
    table_frame.pack(side="right", fill="both", expand=True, padx=10, pady=10)

    columns = ("id", "medicine_name", "dosage", "time", "instructions")
    tree = ttk.Treeview(table_frame, columns=columns, show="headings", height=16)

    tree.heading("id", text="ID")
    tree.heading("medicine_name", text="Medicine")
    tree.heading("dosage", text="Dosage")
    tree.heading("time", text="Time")
    tree.heading("instructions", text="Instructions")

    tree.column("id", width=50, anchor="center")
    tree.column("medicine_name", width=140)
    tree.column("dosage", width=100)
    tree.column("time", width=90)
    tree.column("instructions", width=220)

    tree.pack(fill="both", expand=True)

    def clear_form():
        selected_med_id.set("")
        medicine_name_entry.delete(0, tk.END)
        dosage_entry.delete(0, tk.END)
        time_entry.delete(0, tk.END)
        instructions_entry.delete(0, tk.END)
        feedback.config(text="")

    def load_data():
        for item in tree.get_children():
            tree.delete(item)
        rows = get_medications_db(current_user["id"])
        for row in rows:
            tree.insert("", tk.END, values=row)

    def validate_form():
        if not medicine_name_entry.get().strip():
            return False, "Medicine name is required."
        if not dosage_entry.get().strip():
            return False, "Dosage is required."
        if not time_entry.get().strip():
            return False, "Time is required."
        return True, ""

    def add_record():
        ok, msg = validate_form()
        if not ok:
            feedback.config(text=msg)
            return

        success, result = add_medication_db(
            current_user["id"],
            medicine_name_entry.get().strip(),
            dosage_entry.get().strip(),
            time_entry.get().strip(),
            instructions_entry.get().strip()
        )
        if success:
            load_data()
            clear_form()
            messagebox.showinfo("Success", result)
        else:
            feedback.config(text=result)

    def update_record():
        if not selected_med_id.get():
            feedback.config(text="Select a medication to update.")
            return

        ok, msg = validate_form()
        if not ok:
            feedback.config(text=msg)
            return

        success, result = update_medication_db(
            int(selected_med_id.get()),
            medicine_name_entry.get().strip(),
            dosage_entry.get().strip(),
            time_entry.get().strip(),
            instructions_entry.get().strip()
        )
        if success:
            load_data()
            clear_form()
            messagebox.showinfo("Success", result)
        else:
            feedback.config(text=result)

    def delete_record():
        if not selected_med_id.get():
            feedback.config(text="Select a medication to delete.")
            return

        confirm = messagebox.askyesno("Confirm Delete", "Delete selected medication?")
        if not confirm:
            return

        success, result = delete_medication_db(int(selected_med_id.get()))
        if success:
            load_data()
            clear_form()
            messagebox.showinfo("Success", result)
        else:
            feedback.config(text=result)

    def on_select(event):
        selected = tree.focus()
        if not selected:
            return
        values = tree.item(selected, "values")
        if not values:
            return

        selected_med_id.set(values[0])
        clear_form()
        selected_med_id.set(values[0])
        medicine_name_entry.insert(0, values[1])
        dosage_entry.insert(0, values[2])
        time_entry.insert(0, values[3])
        instructions_entry.insert(0, values[4])

    tree.bind("<<TreeviewSelect>>", on_select)

    btns = tk.Frame(form, bg=CARD_COLOR)
    btns.grid(row=5, column=0, columnspan=2, pady=10)

    make_button(btns, "Add", add_record, 10).grid(row=0, column=0, padx=4, pady=4)
    make_button(btns, "Update", update_record, 10).grid(row=0, column=1, padx=4, pady=4)
    make_button(btns, "Delete", delete_record, 10).grid(row=0, column=2, padx=4, pady=4)
    make_button(btns, "Clear", clear_form, 10).grid(row=1, column=0, padx=4, pady=4)
    make_button(btns, "Back", home, 10).grid(row=1, column=1, padx=4, pady=4)

    load_data()

